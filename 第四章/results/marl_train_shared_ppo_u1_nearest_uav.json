{
  "algorithm": "shared_ppo_centralized_critic",
  "source_inspiration": "minimal PPO/MAPPO-style shared actor with centralized critic, implemented in torch for the unified multi-UAV environment",
  "framework": {
    "torch_version": "2.11.0+cpu",
    "numpy_version": "2.4.3",
    "device": "cpu"
  },
  "config": {
    "seed": 42,
    "num_uavs": 1,
    "assignment_rule": "nearest_uav",
    "train_episodes": 1,
    "eval_episodes": 4,
    "gamma": 0.98,
    "gae_lambda": 0.95,
    "actor_lr": 0.0003,
    "critic_lr": 0.001,
    "hidden_dim": 128,
    "entropy_coef": 0.01,
    "gradient_clip": 0.5,
    "action_std_init": 0.25,
    "action_std_min": 0.08,
    "action_std_decay": 0.995,
    "ppo_epochs": 8,
    "ppo_clip_eps": 0.2,
    "value_clip_eps": 0.2,
    "value_loss_coef": 0.5,
    "minibatch_size": 64,
    "device": "cpu",
    "reward_completion_weight": 1.0,
    "reward_cache_hit_weight": 0.1,
    "reward_latency_weight": 0.05,
    "reward_energy_weight": 1.2,
    "reward_deadline_weight": 0.5,
    "reward_reliability_weight": 0.5,
    "reward_action_magnitude_weight": 0.15
